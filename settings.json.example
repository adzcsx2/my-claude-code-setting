{
  "env": {
    "ANTHROPIC_BASE_URL": "https://api.deepseek.com/anthropic",
    "ANTHROPIC_AUTH_TOKEN": "sk-your-api-key-here",
    "ANTHROPIC_MODEL": "deepseek-v4-pro[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-flash",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-v4-pro[1m]",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "deepseek-v4-pro[1m]",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "API_TIMEOUT_MS": "3000000"
  },
  "permissions": {
    "allow": [
      "Bash(ccb ask *)",
      "Bash(ccb ping *)",
      "Bash(ccb pend *)"
    ],
    "deny": []
  },
  "model": "opus[1m]",
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(find \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud -maxdepth 1 -type d -name \"[0-9]*\" 2>/dev/null | sort -V | tail -1); exec \"/opt/homebrew/bin/node\" \"${plugin_dir}/dist/index.js\"'"
  },
  "enabledPlugins": {
    "figma@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "everything-claude-code@everything-claude-code": true,
    "dev-tools-skills@dev-tools-skills": true
  },
  "extraKnownMarketplaces": {
    "everything-claude-code": {
      "source": {
        "source": "git",
        "url": "https://github.com/affaan-m/everything-claude-code.git"
      }
    }
  },
  "language": "chinese",
  "skipDangerousModePermissionPrompt": true
}
