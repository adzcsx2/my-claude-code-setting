### AL ###
#Template for AL projects for Dynamics 365 Business Central
#launch.json folder
.vscode/
#Cache folder
.alcache/
#Symbols folder
.alpackages/
#Snapshots folder
.snapshots/
#Testing Output folder
.output/
#Extension App-file
*.app
#Rapid Application Development File
rad.json
#Translation Base-file
*.g.xlf
#License-files
*.bclicense
*.flf
#Test results file
TestResults.xml

### Claude local state / cache ###
# Keep portable content such as `ecc/`, `commands/`, `skills/`, `hooks/`,
# `scripts/`, and marketplace plugin sources. Ignore only machine-
# specific runtime state, caches, logs, and disposable artifacts.
# plans/ may contain sensitive credentials and is excluded from version control
plans/
# settings.json contains API keys and other secrets
settings.json
.DS_Store
.agents/
.last-cleanup
history.jsonl
stats-cache.json
settings.local.json
*.log

# Machine-specific state that leaks local paths and install topology
ecc/install-state.json
homunculus/projects.json

# Local MCP overrides and private credentials
mcp-configs/**/*.local.json
mcp-configs/private/

# Secret-bearing local environment and certificate files
.env
.env.*
!.env.example
!.env.template
!.env.sample
!.env.test.example
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer

# Local runtime and generated state
backups/
debug/
file-history/
metrics/
paste-cache/
projects/
session-env/
sessions/
shell-snapshots/
state/
ide/
tasks/
todos/

# Plugin local data only; keep cache content tracked for portable plugin skills
plugins/.DS_Store
plugins/data/
plugins/install-counts-cache.json
plugins/installed_plugins.json
# Plugin runtime files (speed cache, PID markers, etc.)
plugins/**/.speed-cache.json
plugins/**/.in_use/